#!/bin/bash
# pre-commit hook: 防止在 main 分支提交服务代码

current_branch=$(git symbolic-ref --short HEAD)

# 只在 main 分支检查
if [ "$current_branch" != "main" ]; then
    exit 0
fi

# 检查是否有服务代码被修改
service_files=$(git diff --cached --name-only | grep -E "^app/")

if [ -n "$service_files" ]; then
    echo "❌ 错误：不能在 main 分支提交服务代码！"
    echo ""
    echo "main 分支只包含框架代码。服务代码应该在 example 分支开发。"
    echo ""
    echo "检测到以下服务文件："
    echo "$service_files" | sed 's/^/  - /'
    echo ""
    echo "请执行以下操作："
    echo "  1. 取消本次提交: git reset HEAD"
    echo "  2. 切换到 example 分支: git checkout example"
    echo "  3. 在 example 分支提交这些更改"
    echo ""
    exit 1
fi

# 检查是否有部署配置被修改（manifests/, docker-compose.yaml 等）
# 注意：go.work 在两个分支都需要，不算部署配置
deploy_files=$(git diff --cached --name-only | grep -E "^(manifests/|docker-compose\.yaml|docker-compose\.dev\.yaml)")

if [ -n "$deploy_files" ]; then
    echo "❌ 错误：不能在 main 分支提交部署配置！"
    echo ""
    echo "main 分支只包含框架代码和模板。部署配置应该在 example 分支。"
    echo ""
    echo "检测到以下部署文件："
    echo "$deploy_files" | sed 's/^/  - /'
    echo ""
    echo "如果是模板文件，请放在 templates/ 目录下。"
    echo ""
    exit 1
fi

# 检查 Go 代码格式
go_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -n "$go_files" ]; then
    # 检查是否需要格式化
    unformatted=$(echo "$go_files" | xargs gofmt -l 2>/dev/null || true)

    if [ -n "$unformatted" ]; then
        echo "❌ 错误：以下 Go 文件需要格式化！"
        echo ""
        echo "$unformatted" | sed 's/^/  - /'
        echo ""
        echo "请执行以下操作："
        echo "  gofmt -w $unformatted"
        echo "  git add $unformatted"
        echo ""
        exit 1
    fi
fi

exit 0
